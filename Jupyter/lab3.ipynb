    "def swap_xor(a, b):\n",
    "    print(f\"{a} {b}\")\n",
    "    a = a ^ b\n",
    "    b = a ^ b\n",
    "    a = a ^ b\n",
    "    print(f\"{a} {b}\")\n",
    "    return a, b\n",
    "swap_xor(int(input(\"Nhập giá trị a: \")), int(input(\"Nhập giá trị b: \")))"
   ]
